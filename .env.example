# ──────────────────────────────────────────────────────────────────────────
# Solar Forecast Pro — Environment Configuration
# Copy this file to .env and fill in your values.
# The app works in demo mode even without any of these secrets.
# ──────────────────────────────────────────────────────────────────────────

# Demo mode — set to 'false' to require CAMS + PostgreSQL for full training
DEMO_MODE=true

# ── Copernicus ADS / CAMS credentials (optional) ──────────────────────────
# Register free at: https://ads.atmosphere.copernicus.eu/profile
# Required only for CAMS historical data download and XGBoost model training.
CAMS_API_KEY=

# ── PostgreSQL (optional — only for CAMS training data) ───────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=solar_forecast
PGUSER=solar
PGPASSWORD=changeme

# ── Dashboard settings ─────────────────────────────────────────────────────
# Default location shown on first launch
DEFAULT_LAT=47.4979
DEFAULT_LON=19.0402
DEFAULT_LOCATION_NAME=Budapest

# ── API settings ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
